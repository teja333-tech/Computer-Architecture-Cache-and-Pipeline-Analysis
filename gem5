#include <stdio.h>

#define SIZE 80

int main() {
    int arr[SIZE][SIZE];
    int i, j;
    long sum = 0;

    // Initialize array
    for(i = 0; i < SIZE; i++) {
        for(j = 0; j < SIZE; j++) {
            arr[i][j] = i + j;
        }
    }

    // Repeated memory accesses
    for(i = 0; i < SIZE; i++) {
        for(j = 0; j < SIZE; j++) {
            sum += arr[i][j];
        }
    }

    printf("Sum = %ld\n", sum);

    return 0;
}




